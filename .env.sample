# Telegram
TELEGRAM_BOT_TOKEN=

# Database (recommended for persistence)
MONGODB_URI=

# CookMyBots AI Gateway (required for Token Summary / Risk Notes)
# COOKMYBOTS_AI_ENDPOINT is a BASE URL (do NOT include /chat)
COOKMYBOTS_AI_ENDPOINT=https://api.cookmybots.com/api/ai
COOKMYBOTS_AI_KEY=

# AI controls
AI_DEBUG=0
AI_TIMEOUT_MS=600000
AI_MAX_RETRIES=2
AI_MODEL=

# Scanning / alerts
SCAN_COOLDOWN_SECONDS=60
ALERTS_POLL_INTERVAL_SECONDS=60

# Optional admin controls
# Comma-separated Telegram user IDs, example: 12345,67890
ADMIN_TELEGRAM_USER_IDS=
